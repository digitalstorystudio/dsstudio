# ================================================================
# DIGITAL STORY STUDIO - Blog System Environment Variables
# ================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Supabase ──────────────────────────────────────────────
# Get these from: https://supabase.com > Your Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Site Config ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://digitalstorystudio.in
NEXT_PUBLIC_SITE_NAME=Digital Story Studio

# ── Admin Credentials ─────────────────────────────────────
# Set this as the admin email in Supabase Auth
# Then invite yourself via: Supabase Dashboard > Authentication > Users > Invite User
ADMIN_EMAIL=your_admin_email@gmail.com
